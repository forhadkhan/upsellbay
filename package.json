{
	"name": "upsellbay",
	"version": "0.1.0",
	"private": true,
	"sideEffects": true,
	"description": "WooCommerce-native AOV offer engine assets.",
	"scripts": {
		"start": "wp-scripts start --config webpack.config.js",
		"build": "wp-scripts build --config webpack.config.js",
		"dev": "node scripts/dev.js",
		"release": "node scripts/release.js",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:report": "playwright show-report",
		"test:e2e:trace": "playwright test --trace on",
		"i18n:make-pot": "wp i18n make-pot . languages/upsellbay.pot --domain=upsellbay --exclude=node_modules,vendor,.git,.meta,graphify-out,dist",
		"plugin-check": "wp plugin check upsellbay --path=."
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.10.1",
		"@playwright/test": "^1.49.1",
		"@wordpress/scripts": "^30.0.0",
		"archiver": "^7.0.1",
		"fs-extra": "^11.3.1"
	}
}
